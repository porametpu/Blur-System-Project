generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Media {
    id          String   @id @default(cuid())
    fileName    String
    originalUrl String
    blurredUrl  String?
    type        MediaType
    status      Status   @default(PROCESSING)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

enum MediaType {
    IMAGE
    VIDEO
}

enum Status {
    PROCESSING
    COMPLETED
    FAILED
}
